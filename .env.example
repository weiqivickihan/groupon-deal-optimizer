# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: Anthropic API key for Claude (research synthesis + proposal generation)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: delay between deal requests (seconds) to avoid rate limiting
# Default: 3
SCRAPE_DELAY_SECONDS=3

# Optional: output directory (default: ./output)
OUTPUT_DIR=output

# Optional: DuckDB file path (default: ./deals.db)
DB_PATH=deals.db
